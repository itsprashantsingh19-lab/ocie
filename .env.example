# Postgres connection string — works with Supabase, Neon, or Vercel Postgres.
# Get this from:
#   Supabase: Project Settings -> Database -> Connection string (URI, use the
#             "Transaction" pooler string for serverless/Vercel deploys)
#   Neon / Vercel Postgres: shown directly on project creation
DATABASE_URL=postgresql://user:password@host:5432/dbname
